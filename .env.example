APP_SESSION_SECRET=replace-with-long-random-secret
CMS_BASE_URL=https://hoodline.impress3.com
DATABASE_URL=postgresql://hoodline:hoodline@postgres:5432/hoodline
DEFAULT_SUPERUSER_USERNAME=zack@impress3.com
DEFAULT_SUPERUSER_PASSWORD=billGAtes1!1

# Gmail delegated service-account intake (for pipeline step 3.1 gmail_api mode)
GMAIL_DELEGATED_USER=contact@hoodline.com
GMAIL_DEFAULT_QUERY=label:auto/correction-candidate is:unread
# Use one credential source (file path OR inline JSON)
GMAIL_SERVICE_ACCOUNT_FILE=/run/secrets/gmail-service-account.json
GMAIL_SERVICE_ACCOUNT_JSON=

# Classifier (step 3.2)
# CLASSIFIER_BACKEND: auto | claude | rules
CLASSIFIER_BACKEND=auto
CLASSIFIER_MODEL=claude-3-5-sonnet-latest
CLASSIFIER_TIMEOUT_SECONDS=45
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Resolver (step 3.3)
RESOLVER_MIN_SIMILARITY=0.65
RESOLVER_MAX_CANDIDATES=250

# Fetcher (step 3.4)
FETCHER_TIMEOUT_SECONDS=30
FETCHER_USER_AGENT=HoodlineCorrectionsBot/1.0 (+https://hoodline.com)
# Optional CMS auth cookie for probing edit URLs
CMS_FETCHER_SESSION_COOKIE=

# Remediation classifier + note writer (step 3.6)
# REMEDIATION_BACKEND: auto | claude | rules
REMEDIATION_BACKEND=auto
REMEDIATION_MODEL=claude-3-5-sonnet-latest
REMEDIATION_TIMEOUT_SECONDS=45

# Draft stager (step 3.7)
# STAGER_MODE: dry_run | wp_rest
STAGER_MODE=dry_run
STAGER_TIMEOUT_SECONDS=30
STAGER_USER_AGENT=HoodlineDraftStager/1.0 (+https://hoodline.com)
STAGER_ENABLE_REMOTE_WRITES=false
CMS_STAGER_USERNAME=
CMS_STAGER_APP_PASSWORD=
